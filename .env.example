# 复制本文件为 .env，填入你自己的配置
# 不要把 .env 提交到 git（.gitignore 已经屏蔽）

# ============ 知识库路径 ============

# 你的知识库根目录（绝对路径）
# 该目录下应包含 original_file/ 与 md_file/ 子目录
# Windows 用户可以直接粘贴路径，反斜杠不需要转义：
KB_ROOT=D:\你的知识库路径

# 可选：索引数据目录（向量库、缓存、法典等）
# 留空则默认为 <KB_ROOT>\.kb_index
# KB_DATA_DIR=

# ============ API 凭证 ============

# SiliconFlow（向量嵌入 / Reranker）
# 申请：https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek（事实抽取 / AI 格式化 / 法典检查）
# 申请：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
